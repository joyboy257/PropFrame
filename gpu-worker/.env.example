# PropFrame GPU Worker — Environment Variables
# Copy to .env and fill in your values

# ── Railway PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@postgres.railway.internal:5432/railway

# ── Cloudflare R2 ──────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=vugru-media
R2_PUBLIC_URL=https://your-public-r2-url.com

# ── Video Provider ─────────────────────────────────────────────────
# Set VIDEO_PROVIDER to: runway | svd | none
# Defaults to 'runway' if RUNWAY_API_KEY is set, 'svd' if MODAL_SVD_ENDPOINT is set, else 'none'

VIDEO_PROVIDER=runway

# RunwayML Gen-3 API (https://docs.runwayml.com/)
# Free tier: 125 credits. Console: https://account.runwayml.com/
RUNWAY_API_KEY=your_runway_api_key_here

# Stable Video Diffusion — Modal.com GPU app
# Deploy: modal deploy gpu-worker/src/providers/svd_modal_app.py
# After deploying, set your Modal endpoint URL and API token here
MODAL_SVD_ENDPOINT=https://your-modal-app.modal.run
MODAL_SVD_API_TOKEN=your_modal_token_here

# FFmpeg (must be installed on the worker machine) ─────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# ── Worker Config ──────────────────────────────────────────────────
POLL_INTERVAL_MS=3000
LOG_LEVEL=info
